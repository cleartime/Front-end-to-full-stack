{
  "name": "fullstack-transition-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate --schema ${PRISMA_SCHEMA:-prisma/schema.prisma} ${PRISMA_GENERATE_FLAGS:-} && next build",
    "start": "next start -p 3000",
    "db:push": "node scripts/db-push.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:pg:generate": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:pg:push": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:pg:studio": "prisma studio --schema prisma/schema.postgres.prisma",
    "dev:pg": "prisma generate --schema prisma/schema.postgres.prisma && next dev -p 3000",
    "build:pg": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "cf:build": "PRISMA_SCHEMA=prisma/schema.d1.prisma WRANGLER_BUILD_CONDITIONS='' WRANGLER_BUILD_PLATFORM=node opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:db:push": "dotenv -e .dev.vars -- prisma db push --schema prisma/schema.postgres.prisma",
    "cf:db:seed": "dotenv -e .dev.vars -- tsx prisma/seed.ts",
    "cf:db:studio": "dotenv -e .dev.vars -- prisma studio --schema prisma/schema.postgres.prisma",
    "cf:d1:seed": "wrangler d1 execute fullstack-transition-lab-db --remote --file prisma/d1/seed.sql --yes",
    "cf:secret:database": "wrangler secret put DATABASE_URL",
    "cf:secret:auth": "wrangler secret put AUTH_SECRET",
    "postgres:up": "docker compose -f docker-compose.postgres.yml up -d",
    "postgres:down": "docker compose -f docker-compose.postgres.yml down",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/adapter-d1": "^6.19.0",
    "@prisma/adapter-pg": "^6.19.0",
    "@prisma/client": "6.19.0",
    "bcryptjs": "latest",
    "jose": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "pg": "^8.21.0",
    "pg-cloudflare": "^1.4.0",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "dotenv-cli": "^11.0.0",
    "prisma": "6.19.0",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "^4.95.0"
  }
}
